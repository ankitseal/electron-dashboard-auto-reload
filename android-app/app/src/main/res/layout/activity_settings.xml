<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimaryContainer"
        android:title="@string/action_settings"
        android:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
        app:titleCentered="false" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Target card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:text="@string/label_target_section" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <TextView android:text="@string/label_target" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_url"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textUri" />
                    </com.google.android.material.textfield.TextInputLayout>
            <TextView android:text="@string/label_session_auto" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_session"
                            android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:focusable="false" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Login card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:text="@string/label_login_section" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <TextView android:text="@string/label_email" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <TextView android:text="@string/label_password" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:endIconMode="password_toggle">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Auto Refresh card (simplified) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:text="@string/label_auto_refresh_section" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/cb_auto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_auto_refresh_toggle" />
                    <TextView android:text="@string/label_reload_after" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_reload"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Rolling Window card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:text="@string/label_rolling_window_section" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/cb_twenabled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_enable_rolling_window" />
                    <TextView
                        android:id="@+id/tv_twstart_label"
                        android:text="@string/label_daily_start"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_twstart"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_twstart"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:clickable="true"
                            android:hint="@string/hint_twstart" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <TextView
                        android:id="@+id/tv_twdur_label"
                        android:text="@string/label_duration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_twdur"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_twdur"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:clickable="true"
                            android:hint="@string/hint_twdur" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Navigation card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:text="@string/label_navigation_section" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/cb_navback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_nav_back_toggle" />
                    <TextView android:text="@string/label_return_default_after" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_tabto"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2FA card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:text="@string/label_twofa_section" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/cb_twofa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_twofa_toggle" />
                    <TextView
                        android:id="@+id/tv_twofa_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_twofa_status_registered"
                        android:textStyle="bold"
                        android:textColor="#2e7d32"
                        android:visibility="gone"
                        android:paddingTop="4dp" />

                    <TextView android:id="@+id/tv_twofa_secret_label" android:text="@string/label_twofa_secret_label" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_twofa"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_twofa_secret" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="8dp">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_twofa_register"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_twofa_register" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_twofa_remove"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_twofa_remove" />
                    </LinearLayout>

                    <!-- Inline TOTP preview -->
                    <TextView
                        android:id="@+id/tv_totp_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_current_code"
                        android:paddingTop="8dp"
                        android:visibility="gone" />
                    <LinearLayout
                        android:id="@+id/totp_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone"
                        android:paddingTop="4dp">
                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/totp_ring"
                            style="@style/Widget.Material3.CircularProgressIndicator"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            app:indicatorDirectionCircular="clockwise"
                            app:indicatorSize="6dp"
                            app:indicatorColor="#2e7d32"
                            app:trackThickness="6dp"
                            app:trackColor="#e0e0e0"
                            android:indeterminate="false"
                            app:showAnimationBehavior="none"
                            app:hideAnimationBehavior="none" />
                        <TextView
                            android:id="@+id/tv_totp_code"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_totp_code"
                            android:textStyle="bold"
                            android:textSize="22sp"
                            android:fontFamily="monospace"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

        <!-- App version footer -->
        <TextView
            android:id="@+id/tv_version"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:padding="8dp"
            android:text=""
            android:textColor="@android:color/darker_gray"
            android:textSize="12sp" />

</LinearLayout>
